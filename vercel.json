{
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/app/(.*)", "dest": "/index.html" },
    { "src": "/app",     "dest": "/index.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.(?:js|css|png|jpg|svg|ico|woff|woff2|mjs|webp|json))$", "dest": "/$1" },
    { "src": "/",        "dest": "/landing.html" },
    { "src": "/(.*)",    "dest": "/index.html" }
  ]
}
